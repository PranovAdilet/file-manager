generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum FileType {
  folder
  pdf
  txt
  md
  xml
  image
  video
}

model File {
  id         String   @id @default(uuid())
  name       String
  type       FileType

  isFavorite Boolean  @default(false)
  size       Int?
  parentId   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  url        String?
  content    String?
}